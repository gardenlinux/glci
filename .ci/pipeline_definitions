glci:
  base_definition:
    traits:
      notifications:
        default:
          on_error:
            triggering_policy: 'never'

  jobs:
    helpers:
      repo:
        trigger: false
      repos:
      - name: 'GARDENLINUX'
        cfg_name: 'github_com'
        path: 'gardenlinux/gardenlinux'
        branch: 'rel-934'
      steps:
        list-available-releases:
          execute:
          - '../ls-manifests'
          - '--print'
          - 'versions-and-commits'
          image: europe-docker.pkg.dev/gardener-project/releases/cicd/glci-job-image:0.2.0
    manual-release:
      repo:
        trigger: false
      repos:
      - name: 'GARDENLINUX'
        cfg_name: 'github_com'
        path: 'gardenlinux/gardenlinux'
        branch: 'rel-1443'
      - name: 'GARDENLINUX_BUILDER'
        cfg_name: 'github_com'
        path: 'gardenlinux/builder'
        branch: 'main'
      steps:
        publish-gardenlinux-images:
          execute:
          - '../run_publish_release_set.sh'
          - '--version-name'
          - 'default'
          image: europe-docker.pkg.dev/gardener-project/releases/cicd/glci-job-image:0.2.0
